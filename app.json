{
  "expo": {
    "name": "Pulsee",
    "slug": "pulsee",
    "scheme": "pulsee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulsee.app"
    },
    "android": {
      "package": "com.pulsee.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Pulsee to access your camera to record videos and photos.",
          "microphonePermission": "Allow Pulsee to access your microphone to record audio with your videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#08090B"
        }
      ],
      "expo-status-bar",
      "expo-router"
    ]
  }
}
